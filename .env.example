FLASK_ENV=development
FLASK_DEBUG=true
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_ENABLED=true
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STREAMING_LATENCY=1

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

AGENT_MIN_ENDPOINTING_DELAY=0.05
AGENT_MAX_ENDPOINTING_DELAY=0.20
AGENT_MIN_INTERRUPTION_DURATION=0.25

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

CELERY_TASK_ALWAYS_EAGER=true
ADMIN_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/admin/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events
